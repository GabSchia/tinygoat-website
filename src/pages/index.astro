---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="TinyGoat | Claude Adoption Consulting for Revenue Teams" rawTitle={true} description="TinyGoat helps revenue teams at high-growth B2B companies get Claude out of the chat window and into the way they actually sell, manage, and grow.">
  <main class="min-h-screen bg-white relative overflow-hidden">
    <!-- Subtle Atmospheric Background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-1/4 -right-1/4 w-[800px] h-[800px] bg-teal/5 rounded-full blur-[150px]"></div>
      <div class="absolute -bottom-1/4 -left-1/4 w-[600px] h-[600px] bg-gold/5 rounded-full blur-[120px]"></div>
    </div>

    <!-- Noise Texture Overlay -->
    <div class="fixed inset-0 pointer-events-none opacity-[0.03] mix-blend-multiply" style="background-image: url('/noise.png'); background-repeat: repeat;"></div>

    <!-- Content Layer -->
    <div class="relative z-10">
      <Nav />

      <!-- SECTION 1: HERO -->
      <section class="px-6 md:px-12 pt-12 md:pt-20 pb-12 md:pb-16 max-w-4xl mx-auto text-center">
        <h1 class="text-navy text-5xl md:text-6xl lg:text-7xl font-extrabold leading-[1.05] mb-8">
          Access isn't adoption.
        </h1>
        <p class="text-gray-600 text-lg md:text-xl mb-10 leading-relaxed max-w-3xl mx-auto">
          We work with revenue teams at high-growth B2B orgs to get Claude out of the chat window and into the way their team actually works.
        </p>
        <div class="flex justify-center">
          <button
            onclick="Calendly.initPopupWidget({url: 'https://calendly.com/gabby-tinygoat/30min'});return false;"
            class="inline-flex items-center justify-center px-10 py-4 bg-gold text-navy font-semibold text-lg rounded-full hover:shadow-lg hover:shadow-gold/25 hover:-translate-y-0.5 transition-all duration-300 cursor-pointer"
          >
            Book a Free Intro Call
          </button>
        </div>
      </section>

      <!-- SECTION 2: TOOL INTEGRATION VISUAL -->
      <section class="px-6 md:px-12 pb-28 md:pb-36">
        <div class="max-w-4xl mx-auto">
          <div class="flex flex-col items-center">
            <!-- Claude Hub -->
            <div class="flex items-center justify-center mb-4">
              <img src="/logos/Claude%20Icon.png" alt="Claude" class="h-12 md:h-14 w-auto" />
            </div>

            <!-- Tool Logos Row -->
            <div class="flex flex-wrap items-center justify-center gap-6 md:gap-8">
              <img src="/logos/Salesforce_idN3OdcTG__1.png" alt="Salesforce CRM integration with Claude" class="h-8 w-auto opacity-70 hover:opacity-100 transition-opacity" />
              <img src="/logos/HubSpot_Symbol_1.png" alt="HubSpot integration with Claude" class="h-8 w-auto opacity-70 hover:opacity-100 transition-opacity" />
              <img src="/logos/Gong_idnaeh32xQ_1.png" alt="Gong conversation intelligence integration with Claude" class="h-8 w-auto opacity-70 hover:opacity-100 transition-opacity" />
              <img src="/logos/salesloft%20logo%20small.jpeg" alt="Salesloft sales engagement integration with Claude" class="h-8 w-auto opacity-70 hover:opacity-100 transition-opacity" />
              <img src="/logos/Slack_Symbol_1.png" alt="Slack integration with Claude" class="h-14 w-auto opacity-70 hover:opacity-100 transition-opacity -mx-2" />
              <img src="/logos/apollo%20logo.png" alt="Apollo.io prospecting integration with Claude" class="h-8 w-auto opacity-70 hover:opacity-100 transition-opacity" />
              <img src="/logos/Clay%20Arch%20Marque.png" alt="Clay data enrichment integration with Claude" class="h-8 w-auto opacity-70 hover:opacity-100 transition-opacity" />
              <img src="/logos/ZoomInfo_ZI_logomark_red_1.png" alt="ZoomInfo data integration with Claude" class="h-8 w-auto opacity-70 hover:opacity-100 transition-opacity" />
              <img src="/logos/Google_Google_Drive_1.png" alt="Google Drive integration with Claude" class="h-8 w-auto opacity-70 hover:opacity-100 transition-opacity" />
            </div>

            <p class="text-gray-500 text-sm mt-8 text-center font-medium tracking-wide">Claude, embedded into the way your revenue team already works. Connected to your full revenue stack.</p>
          </div>
        </div>
      </section>

      <!-- SECTION 3: SITUATION -->
      <section class="px-6 md:px-12 py-16 md:py-20 bg-gray-50">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-navy text-3xl md:text-4xl font-bold text-center mb-16">
            If you've said any of these out loud, you're in the right place.
          </h2>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
            <div class="bg-white border border-gray-100 rounded-2xl p-8 shadow-sm hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300">
              <p class="text-navy text-lg leading-relaxed italic">"Our CEO loves Claude, but honestly our team isn't sure how to make it work for us."</p>
            </div>
            <div class="bg-white border border-gray-100 rounded-2xl p-8 shadow-sm hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300">
              <p class="text-navy text-lg leading-relaxed italic">"The team has access. We just know we're not using it to its full potential."</p>
            </div>
            <div class="bg-white border border-gray-100 rounded-2xl p-8 shadow-sm hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300">
              <p class="text-navy text-lg leading-relaxed italic">"We're supposed to be using Claude. I just know a lot of the team hasn't really started."</p>
            </div>
          </div>

          <div class="text-center">
            <button
              onclick="Calendly.initPopupWidget({url: 'https://calendly.com/gabby-tinygoat/30min'});return false;"
              class="inline-flex items-center justify-center px-6 py-3 bg-gold text-navy font-semibold rounded-full hover:shadow-lg hover:shadow-gold/25 hover:-translate-y-0.5 transition-all duration-300 cursor-pointer"
            >
              Sound like your team? Let's talk.
            </button>
          </div>
        </div>
      </section>

      <!-- SECTION 4: SOLUTION PIVOT -->
      <section class="px-6 md:px-12 py-24 md:py-32">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-navy text-3xl md:text-4xl font-bold mb-8">
            That is exactly what TinyGoat is built for.
          </h2>
          <p class="text-gray-600 text-lg leading-relaxed max-w-3xl mx-auto">
            We work with revenue teams to get Claude out of the chat window and into the workflows, conversations, and decisions that actually drive pipeline and growth. Whether that means a full implementation built around your org or a focused session on one specific challenge, the goal is always the same. Claude working for your team the way it was designed to.
          </p>
          <div class="flex justify-center mt-3 mb-10">
            <img src="/logos/Claude%20Icon.png" alt="Claude" class="h-9 w-auto" />
          </div>
          <a
            href="/how-we-work"
            class="inline-flex items-center justify-center px-8 py-4 bg-gold text-navy font-semibold text-lg rounded-full hover:shadow-lg hover:shadow-gold/25 hover:-translate-y-0.5 transition-all duration-300"
          >
            See Full Details
          </a>
        </div>
      </section>

      <!-- SECTION: STATS -->
      <section class="px-6 md:px-12 py-20 md:py-28 bg-gray-50">
        <div class="max-w-5xl mx-auto">
          <p class="text-gray-400 text-sm font-medium text-center mb-12 tracking-wide">The numbers behind the work.</p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 text-center">
            <div>
              <p class="text-teal text-5xl md:text-6xl font-extrabold mb-3">70%</p>
              <p class="text-gray-600 text-sm leading-relaxed max-w-xs mx-auto">Of Fortune 100 companies now have Claude embedded in their productivity suite.</p>
              <p class="text-gray-300 text-xs mt-2">Source: Claude AI Statistics, 2025</p>
            </div>
            <div>
              <p class="text-teal text-5xl md:text-6xl font-extrabold mb-3">3.7x</p>
              <p class="text-gray-600 text-sm leading-relaxed max-w-xs mx-auto">Sales reps who use AI consistently are 3.7x more likely to hit quota.</p>
              <p class="text-gray-300 text-xs mt-2">Source: Gartner, 2025</p>
            </div>
            <div>
              <p class="text-teal text-5xl md:text-6xl font-extrabold mb-3">34%</p>
              <p class="text-gray-600 text-sm leading-relaxed max-w-xs mx-auto">Of a sales rep's day is spent actually selling. AI is built to reclaim the rest.</p>
              <p class="text-gray-300 text-xs mt-2">Source: Sales AI Statistics, 2025</p>
            </div>
          </div>
        </div>
      </section>

      <!-- SECTION 7: THE TINYGOAT DIFFERENCE -->
      <section class="px-6 md:px-12 py-24 md:py-32 bg-gray-50">
        <div class="max-w-4xl mx-auto">
          <div class="flex flex-col md:flex-row items-center gap-10">
            <div class="flex-shrink-0">
              <div class="w-32 h-32 md:w-40 md:h-40 rounded-full overflow-hidden border-4 border-white shadow-xl">
                <img src="/Website Photo.png" alt="Gabrielle Schiavenato" class="w-full h-full object-cover object-[50%_35%] scale-150" width="160" height="160" loading="lazy" />
              </div>
            </div>
            <div>
              <h2 class="text-navy text-3xl md:text-4xl font-bold mb-6">
                The TinyGoat difference.
              </h2>
              <p class="text-navy text-lg md:text-xl font-semibold leading-relaxed mb-6">
                TinyGoat is built by someone who has actually carried a quota, managed a pipeline, and trained sales teams from the inside. I know this world because I have lived in it.
              </p>
              <div class="flex flex-col sm:flex-row items-start gap-4">
                <a href="/meet-the-team" class="text-teal hover:underline font-medium text-sm">
                  Learn more about TinyGoat →
                </a>
                <a href="https://www.linkedin.com/in/gabrielleschiavenato" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[#0A66C2] hover:underline font-medium text-sm">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  Follow the work on LinkedIn
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- SECTION 8: CLOSING CTA -->
      <section id="contact" class="px-6 md:px-12 py-24 md:py-32">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-navy text-3xl md:text-4xl lg:text-5xl font-bold mb-6">
            Ready to move from access to adoption?
          </h2>
          <p class="text-gray-600 text-lg mb-10 max-w-xl mx-auto">
            Let's talk about where your team is and what it would take to make Claude actually work for them.
          </p>
          <button
            onclick="Calendly.initPopupWidget({url: 'https://calendly.com/gabby-tinygoat/30min'});return false;"
            class="inline-flex items-center justify-center px-8 py-4 bg-gold text-navy font-bold text-lg rounded-full hover:shadow-lg hover:shadow-gold/25 hover:-translate-y-0.5 transition-all duration-300 cursor-pointer"
          >
            Book a Free 30-Minute Diagnostic
          </button>
          <p class="text-gray-500 text-sm mt-6">
            Prefer email? <a href="mailto:info@tinygoat.ai" class="text-teal hover:underline">info@tinygoat.ai</a>
          </p>
        </div>
      </section>
    </div>

    <Footer />
  </main>
</Layout>
