---
---

<nav class="py-6 px-6 md:px-12 flex items-center justify-between max-w-7xl mx-auto relative">
  <a href="/" class="inline-flex items-center">
    <img src="/tinygoat-logo.png" alt="TinyGoat" class="h-20 md:h-24 w-auto" width="96" height="96" />
  </a>

  <!-- Desktop nav -->
  <div class="hidden md:flex items-center gap-6">
    <a href="/meet-the-team" class="text-gray-600 hover:text-navy transition-colors text-sm font-medium">Meet the Team</a>
    <a href="/how-we-work" class="text-gray-600 hover:text-navy transition-colors text-sm font-medium">How We Work</a>
    <a href="/pricing" class="text-gray-600 hover:text-navy transition-colors text-sm font-medium">Pricing</a>
    <a href="/faq" class="text-gray-600 hover:text-navy transition-colors text-sm font-medium">FAQ</a>
    <button onclick="Calendly.initPopupWidget({url: 'https://calendly.com/gabby-tinygoat/30min'});return false;" class="inline-flex items-center px-5 py-2.5 bg-gold text-navy font-semibold text-sm rounded-full hover:shadow-lg hover:shadow-gold/25 hover:-translate-y-0.5 transition-all duration-300 cursor-pointer">
      Let's Talk
    </button>
  </div>

  <!-- Mobile nav toggle + CTA -->
  <div class="flex md:hidden items-center gap-3">
    <button onclick="Calendly.initPopupWidget({url: 'https://calendly.com/gabby-tinygoat/30min'});return false;" class="inline-flex items-center px-4 py-2 bg-gold text-navy font-semibold text-xs rounded-full cursor-pointer">
      Let's Talk
    </button>
    <button id="mobile-menu-btn" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')" class="text-navy p-2">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu dropdown -->
  <div id="mobile-menu" class="hidden absolute top-full left-0 right-0 bg-white shadow-lg border-t border-gray-100 z-50 md:hidden">
    <div class="flex flex-col py-4 px-6 gap-4">
      <a href="/meet-the-team" class="text-gray-600 hover:text-navy transition-colors text-sm font-medium py-2">Meet the Team</a>
      <a href="/how-we-work" class="text-gray-600 hover:text-navy transition-colors text-sm font-medium py-2">How We Work</a>
      <a href="/pricing" class="text-gray-600 hover:text-navy transition-colors text-sm font-medium py-2">Pricing</a>
      <a href="/faq" class="text-gray-600 hover:text-navy transition-colors text-sm font-medium py-2">FAQ</a>
    </div>
  </div>
</nav>
